# Files excluded when publishing to pub.dev
# https://dart.dev/tools/pub/publishing
#
# When .pubignore exists, it replaces .gitignore for `flutter pub publish`.
# Run `flutter pub publish --dry-run` to verify the file list before publishing.

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IDE
*.iml
*.ipr
*.iws
.idea/
.vscode/

# Flutter/Dart
.dart_tool/
build/
**/doc/api/
pubspec.lock
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/

# Android
**/local.properties
**/.gradle/
**/captures/
**/.cxx/

# iOS / macOS
**/DerivedData/
**/xcuserdata/
**/Pods/
**/Flutter/ephemeral/
**/Flutter/.last_build_id
**/Flutter/Generated.xcconfig
**/Flutter/flutter_export_environment.sh
**/Flutter/GeneratedPluginRegistrant.*

# Example app build artifacts (keep example source for pub.dev)
example/.dart_tool/
example/build/
example/pubspec.lock
example/**/local.properties
example/**/.gradle/
example/**/captures/
example/**/.cxx/

# Symbolication / obfuscation
app.*.symbols
app.*.map.json

# Test coverage
coverage/
